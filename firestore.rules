rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: /organizations/{orgId}
    // Fields: id, name, slug, ownerId, createdAt, settings
    //
    // Collection: /memberships/{membershipId}
    // Fields: id, orgId, userId, role, joinedAt
    //
    // Collection: /organizations/{orgId}/items/{itemId}
    // Fields: id, orgId, sku, name, categoryId, unit, basePrice, sellingPrice, currentStock, reorderThreshold, isActive
    //
    // Collection: /organizations/{orgId}/categories/{categoryId}
    // Fields: id, orgId, name
    //
    // Collection: /organizations/{orgId}/locations/{locationId}
    // Fields: id, orgId, name, type, isDefault
    //
    // Collection: /organizations/{orgId}/transactions/{transactionId}
    // Fields: id, orgId, itemId, type, sourceLocationId, destinationLocationId, quantity, unitCost, unitSellPrice, referenceId, userId, timestamp, status
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId));
    }

    function getMembership(orgId) {
      return get(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId)).data;
    }

    function hasPermission(orgId, permission) {
      let role = getMembership(orgId).role;
      // Simple role-based checks in rules
      return role == 'owner' || role == 'admin' || role == 'manager';
    }

    function isOrgAdmin(orgId) {
      let role = getMembership(orgId).role;
      return role == 'owner' || role == 'admin';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isAuthenticated();
      allow update: if isOrgAdmin(orgId);

      // Nested collections
      match /items/{itemId} {
        allow read: if isOrgMember(orgId);
        allow create, update: if hasPermission(orgId, 'manageItems');
        allow delete: if isOrgAdmin(orgId);
      }

      match /categories/{categoryId} {
        allow read: if isOrgMember(orgId);
        allow create, update: if hasPermission(orgId, 'manageItems');
        allow delete: if isOrgAdmin(orgId);
      }

      match /locations/{locationId} {
        allow read: if isOrgMember(orgId);
        allow create, update: if isOrgAdmin(orgId);
        allow delete: if isOrgAdmin(orgId);
      }

      match /transactions/{transactionId} {
        allow read: if isOrgMember(orgId);
        allow create: if hasPermission(orgId, 'manageInventory');
        // Transactions should generally be immutable
        allow update, delete: if false;
      }
    }

    // Memberships
    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isOrgAdmin(resource.data.orgId));
      allow create: if isAuthenticated(); 
      allow update: if isOrgAdmin(resource.data.orgId);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }
  }
}
